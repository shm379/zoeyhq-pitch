---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="antialiased selection:bg-emerald-500/30 selection:text-emerald-200 bg-dark text-white overflow-x-hidden">
		<div class="noise-overlay"></div>
		
		<slot />
	</body>
</html>

<style is:global>
	/* Cinematic Film Grain Overlay */
	.noise-overlay {
		position: fixed;
		top: 0; left: 0; width: 100vw; height: 100vh;
		pointer-events: none;
		z-index: 9999;
		opacity: 0.06;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
	}

	/* Performance Optimizations */
	.will-change-transform { 
		will-change: transform, opacity, filter; 
		backface-visibility: hidden;
	}
	.gpu-accelerated { transform: translateZ(0); }
	
	/* Scrollbar */
	::-webkit-scrollbar { width: 6px; }
	::-webkit-scrollbar-track { background: #050505; }
	::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
	::-webkit-scrollbar-thumb:hover { background: #555; }

	/* Typography Glows */
	.glow-text-emerald { text-shadow: 0 0 40px rgba(16, 185, 129, 0.4); }
	.glow-text-orange { text-shadow: 0 0 40px rgba(249, 115, 22, 0.4); }

	/* Glassmorphism Panels */
	.glass-panel {
		background: rgba(255, 255, 255, 0.02);
		backdrop-filter: blur(24px);
		-webkit-backdrop-filter: blur(24px);
		border: 1px solid rgba(255, 255, 255, 0.08);
		box-shadow: 0 30px 60px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1);
	}

	/* GPU Optimized AI Scanner Line */
	.scanner-beam {
		height: 40px;
		background: linear-gradient(to bottom, transparent, rgba(16,185,129,0.1) 60%, rgba(16,185,129,0.6) 100%);
		border-bottom: 2px solid rgba(16,185,129,0.9);
		box-shadow: 0 5px 20px rgba(16,185,129,0.5);
		transform: translateY(-100%); 
	}
</style>
