---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<meta name="description" content="ZoeyHQ — The AI-powered real estate CRM built from the Gulf for MENA. Qualify leads, close deals, and never miss a follow-up across WhatsApp, Telegram & Instagram.">
		<meta property="og:title" content="ZoeyHQ | AI Real Estate CRM for MENA">
		<meta property="og:description" content="The AI-powered real estate platform that qualifies leads 24/7 in Arabic, English & Farsi.">
		<meta property="og:type" content="website">
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap" rel="stylesheet">
	</head>
	<body class="antialiased selection:bg-emerald-500/30 selection:text-emerald-200 bg-dark text-white overflow-x-hidden">
		<div class="noise-overlay"></div>
		
		<slot />
	</body>
</html>

<style is:global>
	/* Optimized Noise Overlay */
	.noise-overlay {
		position: fixed;
		top: 0; left: 0; width: 100vw; height: 100vh;
		pointer-events: none;
		z-index: 9999;
		opacity: 0.04;
		background-image: url("https://grainy-gradients.vercel.app/noise.svg");
		background-repeat: repeat;
		mix-blend-mode: overlay;
	}

	/* Performance Optimizations */
	.will-change-transform { 
		will-change: transform, opacity; 
		backface-visibility: hidden;
	}
	.gpu-accelerated { transform: translate3d(0,0,0); }
	
	/* Scrollbar */
	::-webkit-scrollbar { width: 6px; }
	::-webkit-scrollbar-track { background: #050505; }
	::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
	::-webkit-scrollbar-thumb:hover { background: #555; }

	/* Typography Glows */
	.glow-text-emerald { text-shadow: 0 0 30px rgba(16, 185, 129, 0.3); }
	.glow-text-orange { text-shadow: 0 0 30px rgba(249, 115, 22, 0.3); }

	/* Glassmorphism Panels */
	.glass-panel {
		background: rgba(255, 255, 255, 0.03);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid rgba(255, 255, 255, 0.1);
		box-shadow: 0 20px 40px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05);
	}

	/* GPU Optimized AI Scanner Line */
	.scanner-beam {
		height: 40px;
		background: linear-gradient(to bottom, transparent, rgba(16,185,129,0.1) 60%, rgba(16,185,129,0.6) 100%);
		border-bottom: 2px solid rgba(16,185,129,0.9);
		box-shadow: 0 5px 20px rgba(16,185,129,0.5);
		transform: translateY(-100%); 
	}
</style>
