<style>
    .feature-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 20px 40px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.05);
        padding: 1.75rem;
        border-radius: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }
    .feature-card:hover {
        transform: translateY(-6px);
        border-color: rgba(255,255,255,0.15);
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
</style>

<script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from '@studio-freight/lenis';

    gsap.registerPlugin(ScrollTrigger);

    const lenis = new Lenis({
        duration: 0.8,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smooth: true,
        smoothTouch: false
    });

    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => { lenis.raf(time * 1000); });
    gsap.ticker.lagSmoothing(500, 33);

    // Pinned story timeline
    const tl = gsap.timeline({
        scrollTrigger: {
            trigger: "#story-pin",
            start: "top top",
            end: "+=4500",
            scrub: 0.5,
            pin: true,
            anticipatePin: 1
        },
        defaults: { ease: "none", force3D: true }
    });

    // PHASE 1: Hero -> Chaos
    tl.addLabel("startChaos")
      .to(".scene-hero", { opacity: 0, y: -50, duration: 1 }, "startChaos")
      .to(".orb-hero", { opacity: 0, duration: 1 }, "startChaos")
      .to(".orb-chaos", { opacity: 1, duration: 1 }, "startChaos+=0.5")
      .fromTo(".scene-chaos",
            { opacity: 0, scale: 1.05 },
            { opacity: 1, scale: 1, duration: 1.5, ease: "power2.out" }, "startChaos+=0.5")
      .from(".target-message", { scale: 0.8, opacity: 0, rotation: -5, duration: 1, ease: "back.out(1.5)"}, "startChaos+=1")
      .to(".target-message", { scale: 1.05, boxShadow: "0 0 80px rgba(225,29,72,0.4)", duration: 1, yoyo: true, repeat: 1 }, "startChaos+=1.5");

    // PHASE 2: Chaos -> Journey
    tl.addLabel("startJourney", "+=0.5")
      .to(".scene-chaos", { opacity: 0, y: -50, scale: 0.9, duration: 1 }, "startJourney")
      .to(".orb-chaos", { opacity: 0, duration: 1 }, "startJourney")
      .to(".orb-solution", { opacity: 1, duration: 1 }, "startJourney+=0.5")
      .fromTo(".scene-journey",
            { opacity: 0, scale: 1.05, y: 50 },
            { opacity: 1, scale: 1, y: 0, duration: 1.5, ease: "power3.out" }, "startJourney+=0.5")
      .from(".solution-dash", { rotationX: -10, rotationY: -20, z: -200, duration: 1.5, ease: "power2.out" }, "startJourney+=0.5");

    // PHASE 3: Micro-interactions
    tl.addLabel("ingestMsg", "+=0.5")
      .to(".msg-card", { opacity: 1, y: 0, duration: 1, ease: "back.out(1.2)" }, "ingestMsg");

    tl.addLabel("scanMsg", "+=0.8")
      .to(".flow-text-1", { opacity: 0, y: -30, duration: 0.8 }, "scanMsg")
      .to(".flow-text-2", { opacity: 1, y: 0, duration: 0.8 }, "scanMsg+=0.2")
      .to(".scanner-bar", { opacity: 1, duration: 0.2 }, "scanMsg")
      .to(".scanner-bar", { y: "500%", duration: 1.5, ease: "power1.inOut" }, "scanMsg+=0.2")
      .to(".scanner-bar", { opacity: 0, duration: 0.2 }, "scanMsg+=1.7")
      .to(".ai-analysis-wrapper", { opacity: 1, height: "auto", duration: 1.2, ease: "power3.out" }, "scanMsg+=1.2");

    // PHASE 4: Conversion
    tl.addLabel("convertLead", "+=1")
      .to(".flow-text-2", { opacity: 0, y: -30, duration: 0.8 }, "convertLead")
      .to(".flow-text-3", { opacity: 1, y: 0, duration: 0.8 }, "convertLead+=0.2")
      .to(".orb-solution", { opacity: 0, duration: 1 }, "convertLead")
      .to(".orb-features", { opacity: 1, duration: 1 }, "convertLead")
      .to(".msg-card", {
          borderColor: "rgba(249, 115, 22, 0.5)",
          backgroundColor: "rgba(249, 115, 22, 0.05)",
          boxShadow: "0 0 40px rgba(249, 115, 22, 0.15)",
          scale: 1.02,
          duration: 1,
          ease: "back.out(1.5)"
      }, "convertLead");

    // PHASE 5: Journey -> Gulf Pride
    tl.addLabel("startAsk", "+=1")
      .to(".scene-journey", { opacity: 0, y: -50, scale: 0.9, duration: 1 }, "startAsk")
      .fromTo(".scene-ask",
            { opacity: 0, scale: 1.05 },
            { opacity: 1, scale: 1, duration: 1.5, ease: "power3.out" }, "startAsk+=0.5");

    // Scroll-triggered fade-in for sections below the pin
    gsap.utils.toArray('#features, #compare, #pricing, #invest').forEach((section) => {
        gsap.from(section as HTMLElement, {
            scrollTrigger: {
                trigger: section as HTMLElement,
                start: "top 85%",
                toggleActions: "play none none none"
            },
            opacity: 0,
            y: 40,
            duration: 1,
            ease: "power3.out"
        });
    });
</script>
