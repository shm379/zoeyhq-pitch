            <div class="text-center md:text-left">
                <a href="https://zoeyhq.website" target="_blank" class="font-bold text-xl tracking-widest text-white hover:text-emerald-400 transition-colors">
                    ZOEY<span class="text-emerald-500">HQ</span>
                </a>
                <p class="text-white/30 text-xs mt-2">Built with passion from the Gulf · © 2025 ZoeyHQ</p>
            </div>
            <div class="flex items-center gap-6">
                <a href="https://zoeyhq.website" target="_blank" class="text-white/40 text-sm hover:text-white transition-colors">Platform</a>
                <a href="#pricing" class="text-white/40 text-sm hover:text-white transition-colors">Pricing</a>
