---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ZoeyHQ | AI Real Estate CRM — Investor Pitch">

    <!-- Nav -->
    <nav class="fixed top-0 w-full z-50 backdrop-blur-xl bg-white/95 border-b border-slate-200">
        <div class="max-w-6xl mx-auto px-6 h-16 flex justify-between items-center">
            <a href="https://zoeyhq.website" target="_blank" class="font-bold text-lg tracking-widest text-slate-900 hover:text-emerald-600 transition-colors">
                ZOEY<span class="text-emerald-500">HQ</span>
            </a>
            <div class="hidden md:flex items-center gap-8">
                <a href="#problem" class="text-slate-500 text-xs uppercase tracking-wider hover:text-slate-900 transition-colors">Problem</a>
                <a href="#solution" class="text-slate-500 text-xs uppercase tracking-wider hover:text-slate-900 transition-colors">Solution</a>
                <a href="#features" class="text-slate-500 text-xs uppercase tracking-wider hover:text-slate-900 transition-colors">Features</a>
                <a href="#compare" class="text-slate-500 text-xs uppercase tracking-wider hover:text-slate-900 transition-colors">Compare</a>
                <a href="#pricing" class="text-slate-500 text-xs uppercase tracking-wider hover:text-slate-900 transition-colors">Pricing</a>
                <a href="#invest" class="px-4 py-2 rounded-full bg-emerald-500 text-black text-xs font-bold hover:bg-emerald-400 transition-all">Invest</a>
            </div>
            <a href="#invest" class="md:hidden px-4 py-2 rounded-full bg-emerald-500 text-black text-xs font-bold">Invest</a>
        </div>
    </nav>

    <!-- ═══════════════════════════════════ -->
    <!-- HERO  (dark photo overlay)         -->
    <!-- ═══════════════════════════════════ -->
    <section class="relative min-h-screen flex items-center justify-center px-6 pt-16 overflow-hidden">
        <!-- Background: Dubai Marina at night -->
        <div class="absolute inset-0">
            <img
                src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=1920&q=85&auto=format&fit=crop"
                class="w-full h-full object-cover"
                alt="Dubai skyline"
                loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-b from-black/75 via-black/50 to-slate-50"></div>
            <div class="absolute inset-0 bg-emerald-950/15"></div>
        </div>

        <div class="relative z-10 max-w-5xl mx-auto text-center fade-up">
            <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-white/10 border border-white/20 backdrop-blur-md mb-10">
                <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_12px_#10b981]"></span>
                <span class="text-xs font-semibold text-white/90 tracking-widest uppercase">Built from the Gulf · For MENA</span>
            </div>

            <h1 class="text-5xl md:text-7xl lg:text-[5.5rem] font-extrabold text-white mb-8 tracking-tighter leading-[1.05]">
                The AI That Turns<br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-300">Messages into Revenue.</span>
            </h1>

            <p class="text-lg md:text-xl text-white/70 max-w-2xl mx-auto mb-12 font-light leading-relaxed">
                AI-powered real estate CRM that qualifies leads, drafts replies, and closes deals 24/7 — in Arabic &amp; English.
            </p>

            <!-- Stats -->
            <div class="flex flex-wrap justify-center gap-8 md:gap-14 mb-12">
                <div class="text-center">
                    <div class="text-4xl md:text-5xl font-black text-white tracking-tight">24/7</div>
                    <div class="text-xs text-white/50 uppercase tracking-wider mt-1">AI Sales Agent</div>
                </div>
                <div class="text-center">
                    <div class="text-4xl md:text-5xl font-black text-white tracking-tight">3x</div>
                    <div class="text-xs text-white/50 uppercase tracking-wider mt-1">More Closings</div>
                </div>
                <div class="text-center">
                    <div class="text-4xl md:text-5xl font-black text-white tracking-tight">90<span class="text-emerald-400 text-2xl">%</span></div>
                    <div class="text-xs text-white/50 uppercase tracking-wider mt-1">Faster Response</div>
                </div>
                <div class="text-center">
                    <div class="text-4xl md:text-5xl font-black text-white tracking-tight">$8M</div>
                    <div class="text-xs text-white/50 uppercase tracking-wider mt-1">Competitor Raised</div>
                </div>
            </div>

            <!-- CTAs -->
            <div class="flex flex-wrap justify-center gap-4 mb-14">
                <a href="#invest" class="px-7 py-3.5 rounded-full bg-emerald-500 text-black font-bold text-sm hover:bg-emerald-400 transition-all shadow-[0_0_30px_rgba(16,185,129,0.4)] hover:shadow-[0_0_50px_rgba(16,185,129,0.6)]">
                    Invest in ZoeyHQ →
                </a>
                <a href="#solution" class="px-7 py-3.5 rounded-full bg-white/10 border border-white/25 text-white font-medium text-sm hover:bg-white/20 backdrop-blur-sm transition-all">
                    See How It Works
                </a>
            </div>

            <!-- Country badges -->
            <div class="flex flex-wrap justify-center gap-2">
                <span class="px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs backdrop-blur-sm">🇦🇪 UAE</span>
                <span class="px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs backdrop-blur-sm">🇸🇦 Saudi Arabia</span>
                <span class="px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs backdrop-blur-sm">🇮🇶 Iraq</span>
                <span class="px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs backdrop-blur-sm">🇰🇼 Kuwait</span>
                <span class="px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs backdrop-blur-sm">🇶🇦 Qatar</span>
                <span class="px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs backdrop-blur-sm">🇧🇭 Bahrain</span>
                <span class="px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs backdrop-blur-sm">🇴🇲 Oman</span>
                <span class="px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs backdrop-blur-sm">🇪🇬 Egypt</span>
                <span class="px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs backdrop-blur-sm">🇯�� Jordan</span>
                <span class="px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs backdrop-blur-sm">🇲🇦 Morocco</span>
                <span class="px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-white/90 text-xs backdrop-blur-sm">🇱🇧 Lebanon</span>
            </div>
        </div>

        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-50">
            <span class="text-[10px] text-white uppercase tracking-widest">Scroll</span>
            <div class="w-5 h-8 rounded-full border border-white/30 flex items-start justify-center p-1">
                <div class="w-1 h-2 bg-white rounded-full animate-bounce"></div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════ -->
    <!-- CITY SHOWCASE                       -->
    <!-- ═══════════════════════════════════ -->
    <section class="py-0 overflow-hidden border-y border-slate-200">
        <div class="grid grid-cols-2 md:grid-cols-5" style="height:260px">
            <div class="relative group overflow-hidden">
                <img src="https://images.unsplash.com/photo-1582672060674-bc2bd808a8b5?w=600&q=80&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Dubai" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <div class="absolute bottom-4 left-4">
                    <div class="text-white font-bold text-sm">🇦🇪 Dubai</div>
                    <div class="text-white/55 text-[10px] uppercase tracking-wider">UAE</div>
                </div>
            </div>
            <div class="relative group overflow-hidden">
                <img src="https://images.unsplash.com/photo-1586724237569-f3d0c1dee8c6?w=600&q=80&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Riyadh" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <div class="absolute bottom-4 left-4">
                    <div class="text-white font-bold text-sm">🇸🇦 Riyadh</div>
                    <div class="text-white/55 text-[10px] uppercase tracking-wider">Saudi Arabia</div>
                </div>
            </div>
            <div class="relative group overflow-hidden">
                <img src="https://images.unsplash.com/photo-1566024287286-457247b70310?w=600&q=80&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Baghdad" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <div class="absolute bottom-4 left-4">
                    <div class="text-white font-bold text-sm">🇮🇶 Baghdad</div>
                    <div class="text-white/55 text-[10px] uppercase tracking-wider">Iraq</div>
                </div>
            </div>
            <div class="relative group overflow-hidden">
                <img src="https://images.unsplash.com/photo-1568322445389-f64ac2515020?w=600&q=80&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Cairo" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <div class="absolute bottom-4 left-4">
                    <div class="text-white font-bold text-sm">🇪🇬 Cairo</div>
                    <div class="text-white/55 text-[10px] uppercase tracking-wider">Egypt</div>
                </div>
            </div>
            <div class="relative group overflow-hidden col-span-2 md:col-span-1">
                <img src="https://images.unsplash.com/photo-1578574577315-3fbeb0cecdc2?w=600&q=80&auto=format&fit=crop" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Doha" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <div class="absolute bottom-4 left-4">
                    <div class="text-white font-bold text-sm">🇶🇦 Doha</div>
                    <div class="text-white/55 text-[10px] uppercase tracking-wider">Qatar</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════ -->
    <!-- PROBLEM                             -->
    <!-- ═══════════════════════════════════ -->
    <section id="problem" class="py-28 px-6">
        <div class="max-w-6xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div class="fade-up">
                    <span class="text-rose-500 tracking-widest text-xs font-bold uppercase mb-5 block">The Problem</span>
                    <h2 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6 leading-tight tracking-tight">
                        Leads Come In.<br><span class="text-rose-400">Revenue Walks Out.</span>
                    </h2>
                    <p class="text-slate-500 text-lg font-light leading-relaxed mb-8">
                        Every day, real estate agencies across the Gulf lose thousands of dollars in potential deals. Messages pile up across WhatsApp, Telegram, and Instagram. Agents can't keep up. Hot leads go cold. Cash buyers move on.
                    </p>
                    <div class="space-y-4">
                        <div class="flex items-start gap-4">
                            <div class="w-8 h-8 rounded-lg bg-rose-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                                <span class="text-rose-400 text-sm">✗</span>
                            </div>
                            <div>
                                <div class="text-slate-900 font-medium text-sm">72% of leads never get a reply within the first hour</div>
                                <div class="text-slate-400 text-xs mt-0.5">Speed-to-lead is the #1 predictor of conversion</div>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div class="w-8 h-8 rounded-lg bg-rose-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                                <span class="text-rose-400 text-sm">✗</span>
                            </div>
                            <div>
                                <div class="text-slate-900 font-medium text-sm">Messages scattered across 4+ platforms</div>
                                <div class="text-slate-400 text-xs mt-0.5">No unified view, no tracking, no accountability</div>
                            </div>
                        </div>
                        <div class="flex items-start gap-4">
                            <div class="w-8 h-8 rounded-lg bg-rose-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                                <span class="text-rose-400 text-sm">✗</span>
                            </div>
                            <div>
                                <div class="text-slate-900 font-medium text-sm">No follow-up system means cold leads stay cold</div>
                                <div class="text-slate-400 text-xs mt-0.5">$50K+ lost per agency per month in missed opportunities</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Visual: Chaos card -->
                <div class="fade-up relative">
                    <div class="card-panel p-6 rounded-3xl relative overflow-hidden">
                        <div class="absolute inset-0 bg-gradient-to-br from-rose-500/5 to-transparent pointer-events-none"></div>
                        <div class="space-y-3 relative z-10">
                            <!-- Unread messages stack -->
                            <div class="bg-slate-50 rounded-xl p-4 border border-slate-200 relative">
                                <div class="absolute top-3 right-3 w-5 h-5 rounded-full bg-rose-500 text-[10px] font-bold text-white flex items-center justify-center">47</div>
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-[#25D366]/20 flex items-center justify-center"><span class="text-[#25D366] text-xs font-bold">WA</span></div>
                                    <div class="flex-1">
                                        <div class="text-slate-900 text-xs font-medium">WhatsApp Business</div>
                                        <div class="text-slate-400 text-[11px]">47 unread messages...</div>
                                    </div>
                                    <span class="text-slate-300 text-[10px]">2h ago</span>
                                </div>
                            </div>
                            <div class="bg-slate-50 rounded-xl p-4 border border-slate-200 relative">
                                <div class="absolute top-3 right-3 w-5 h-5 rounded-full bg-rose-500 text-[10px] font-bold text-white flex items-center justify-center">23</div>
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center"><span class="text-blue-400 text-xs font-bold">TG</span></div>
                                    <div class="flex-1">
                                        <div class="text-slate-900 text-xs font-medium">Telegram</div>
                                        <div class="text-slate-400 text-[11px]">23 unread messages...</div>
                                    </div>
                                    <span class="text-slate-300 text-[10px]">5h ago</span>
                                </div>
                            </div>
                            <div class="bg-slate-50 rounded-xl p-4 border border-slate-200 relative">
                                <div class="absolute top-3 right-3 w-5 h-5 rounded-full bg-rose-500 text-[10px] font-bold text-white flex items-center justify-center">12</div>
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-pink-500/20 flex items-center justify-center"><span class="text-pink-400 text-xs font-bold">IG</span></div>
                                    <div class="flex-1">
                                        <div class="text-slate-900 text-xs font-medium">Instagram DMs</div>
                                        <div class="text-slate-400 text-[11px]">12 unread messages...</div>
                                    </div>
                                    <span class="text-slate-300 text-[10px]">1d ago</span>
                                </div>
                            </div>
                            <div class="bg-rose-500/5 rounded-xl p-4 border border-rose-500/20 mt-2">
                                <div class="flex items-center gap-2 text-rose-400 text-xs font-medium">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                                    <span>3 hot leads went cold in the last 24 hours</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════ -->
    <!-- SOLUTION                            -->
    <!-- ═══════════════════════════════════ -->
    <section id="solution" class="py-28 px-6 relative">
        <div class="absolute inset-0 pointer-events-none">
            <div class="absolute w-[40vw] h-[40vw] bg-emerald-600/5 rounded-full blur-[100px] top-1/3 right-0"></div>
        </div>
        <div class="max-w-6xl mx-auto relative z-10">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <!-- Visual: Dashboard mock -->
                <div class="fade-up order-2 lg:order-1">
                    <div class="card-panel rounded-3xl overflow-hidden">
                        <div class="bg-slate-100 h-10 border-b border-slate-200 flex items-center px-5 justify-between">
                            <div class="flex items-center gap-2">
                                <div class="w-2.5 h-2.5 rounded-full bg-slate-200"></div>
                                <div class="w-2.5 h-2.5 rounded-full bg-slate-200"></div>
                                <div class="w-2.5 h-2.5 rounded-full bg-slate-200"></div>
                            </div>
                            <div class="text-[10px] font-bold tracking-widest text-emerald-400 uppercase">ZoeyHQ Dashboard</div>
                            <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                        </div>
                        <div class="p-5 space-y-3">
                            <!-- Incoming message -->
                            <div class="bg-slate-50 rounded-xl p-4 border border-slate-200">
                                <div class="flex items-start gap-3">
                                    <div class="w-9 h-9 rounded-full bg-[#25D366]/15 flex items-center justify-center text-[10px] font-bold text-[#25D366] flex-shrink-0">WA</div>
                                    <div class="flex-1 min-w-0">
                                        <div class="flex justify-between items-center mb-1.5">
                                            <span class="text-slate-900 text-xs font-medium">Ahmed Al-Rashidi</span>
                                            <span class="text-[10px] text-slate-400">Just now</span>
                                        </div>
                                        <p class="text-slate-500 text-xs leading-relaxed">"Hi, I'm a cash buyer looking at the luxury villa in Palm Jumeirah. What's the final price?"</p>
                                    </div>
                                </div>
                            </div>
                            <!-- AI Analysis -->
                            <div class="bg-emerald-500/5 rounded-xl p-4 border border-emerald-500/20">
                                <div class="flex items-center gap-2 mb-3">
                                    <div class="w-5 h-5 rounded-full bg-emerald-500/20 flex items-center justify-center">
                                        <span class="text-emerald-400 text-[10px]">⚡</span>
                                    </div>
                                    <span class="text-emerald-400 text-[10px] font-bold uppercase tracking-wider">AI Analysis — 0.8s</span>
                                </div>
                                <div class="grid grid-cols-3 gap-2 mb-3">
                                    <div class="bg-slate-200 rounded-lg p-2 text-center">
                                        <div class="text-[9px] text-slate-400 uppercase mb-0.5">Score</div>
                                        <div class="text-emerald-400 text-sm font-bold">92/100</div>
                                    </div>
                                    <div class="bg-slate-200 rounded-lg p-2 text-center">
                                        <div class="text-[9px] text-slate-400 uppercase mb-0.5">Intent</div>
                                        <div class="text-orange-400 text-[11px] font-mono font-medium">Purchase</div>
                                    </div>
                                    <div class="bg-slate-200 rounded-lg p-2 text-center">
                                        <div class="text-[9px] text-slate-400 uppercase mb-0.5">Budget</div>
                                        <div class="text-slate-600 text-[11px] font-mono font-medium">Cash Ready</div>
                                    </div>
                                </div>
                                <div class="bg-emerald-900/20 rounded-lg p-3 border border-emerald-500/10">
                                    <div class="text-[9px] text-emerald-400/60 uppercase mb-1 font-bold">AI-Drafted Reply</div>
                                    <p class="text-slate-600 text-xs italic leading-relaxed">"Hello Ahmed! The villa is available at AED 5.5M. As a cash buyer, you qualify for a priority private viewing. Shall I book one for today?"</p>
                                </div>
                            </div>
                            <!-- Action buttons -->
                            <div class="flex gap-2">
                                <button class="flex-1 py-2.5 rounded-xl bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 text-xs font-medium">✓ Send Reply</button>
                                <button class="flex-1 py-2.5 rounded-xl bg-slate-100 border border-slate-200 text-slate-500 text-xs font-medium">✎ Edit</button>
                                <button class="py-2.5 px-4 rounded-xl bg-slate-100 border border-slate-200 text-slate-500 text-xs font-medium">···</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="fade-up order-1 lg:order-2">
                    <span class="text-emerald-500 tracking-widest text-xs font-bold uppercase mb-5 block">The Solution</span>
                    <h2 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6 leading-tight tracking-tight">
                        Every Message.<br><span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500">Qualified in Seconds.</span>
                    </h2>
                    <p class="text-slate-500 text-lg font-light leading-relaxed mb-8">
                        ZoeyHQ captures every message from every channel, scores leads instantly with AI, drafts personalized replies, and moves them through your pipeline — all before your agent picks up their phone.
                    </p>
                    <div class="space-y-5">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center flex-shrink-0">
                                <span class="text-emerald-400 font-bold text-sm">1</span>
                            </div>
                            <div>
                                <div class="text-slate-900 font-medium text-sm">Message arrives from any channel</div>
                                <div class="text-slate-400 text-xs">WhatsApp, Telegram, Instagram — unified instantly</div>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center flex-shrink-0">
                                <span class="text-emerald-400 font-bold text-sm">2</span>
                            </div>
                            <div>
                                <div class="text-slate-900 font-medium text-sm">AI scores and qualifies in under 1 second</div>
                                <div class="text-slate-400 text-xs">Budget, intent, timeline — all extracted automatically</div>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center flex-shrink-0">
                                <span class="text-emerald-400 font-bold text-sm">3</span>
                            </div>
                            <div>
                                <div class="text-slate-900 font-medium text-sm">Agent reviews AI draft, hits send</div>
                                <div class="text-slate-400 text-xs">You stay in control — AI assists, humans decide</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══════════════════════════════════ -->
    <!-- FEATURES                            -->
