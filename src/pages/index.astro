---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ZoeyHQ | Pitch Deck">
    <nav class="fixed top-0 w-full p-6 z-50 flex justify-between items-center mix-blend-difference">
        <a href="https://zoeyhq.website" target="_blank" class="font-bold text-xl tracking-widest text-white hover:text-emerald-400 transition-colors">
            ZOEY<span class="text-emerald-500">HQ</span>
        </a>
        <button class="px-5 py-2 rounded-full border border-white/20 text-white text-sm hover:bg-white hover:text-black transition-all font-medium">Invest Now</button>
    </nav>

    <div id="story-pin" class="relative w-full h-screen bg-dark overflow-hidden flex items-center justify-center">
        
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-0 mix-blend-screen">
            <div class="orb-hero absolute w-[60vw] h-[60vw] bg-slate-800/30 rounded-full blur-[120px] opacity-100 gpu-accelerated"></div>
            <div class="orb-chaos absolute w-[50vw] h-[50vw] bg-rose-600/15 rounded-full blur-[120px] opacity-0 translate-x-1/4 -translate-y-1/4 gpu-accelerated"></div>
            <div class="orb-solution absolute w-[45vw] h-[45vw] bg-emerald-600/15 rounded-full blur-[120px] opacity-0 -translate-x-1/4 translate-y-1/4 gpu-accelerated"></div>
            <div class="orb-features absolute w-[55vw] h-[55vw] bg-orange-600/10 rounded-full blur-[120px] opacity-0 gpu-accelerated"></div>
        </div>

        <div class="scene-hero absolute inset-0 w-full h-full flex flex-col items-center justify-center z-10 px-6 will-change-transform">
            <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-md mb-8">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse shadow-[0_0_10px_#10b981]"></span>
                <span class="text-xs font-semibold text-white/80 tracking-widest uppercase">The Anatomy of an AI Lead</span>
            </div>
            <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold text-white mb-6 text-center tracking-tighter leading-[1.1]">
                Watch a Message <br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-600 glow-text-emerald">Turn into Revenue.</span>
            </h1>
            <p class="text-lg md:text-xl text-white/50 text-center max-w-2xl px-4 mb-12 font-light">
                Experience the exact journey of a client's message flowing through ZoeyHQ's neural engine.
            </p>
        </div>

        <div class="scene-chaos absolute inset-0 w-full h-full flex items-center justify-center z-20 opacity-0 pointer-events-none px-6 lg:px-20 will-change-transform">
            <div class="w-full max-w-7xl flex flex-col lg:flex-row items-center gap-12">
                <div class="w-full lg:w-1/2">
                    <span class="text-rose-500 tracking-widest text-xs font-bold uppercase mb-4 block">Stage 01 / The Raw Input</span>
                    <h2 class="text-4xl md:text-6xl font-extrabold text-white mb-6 leading-tight tracking-tight">
                        The Noise <br><span class="text-rose-400">Before Zoey.</span>
                    </h2>
                    <p class="text-white/60 text-lg md:text-xl font-light leading-relaxed">
                        A raw message arrives in your WhatsApp. In a normal day, this message gets lost among hundreds of notifications and spam.
                    </p>
                </div>
                <div class="w-full lg:w-1/2 h-[400px] relative perspective-[1000px]">
                    <div class="target-message absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 glass-panel p-5 rounded-3xl border-emerald-500/50 shadow-[0_0_50px_rgba(16,185,129,0.2)] w-80">
                        <div class="flex items-center gap-3 mb-3">
                            <div class="w-8 h-8 rounded-full bg-[#25D366]/20 flex items-center justify-center border border-[#25D366]/50">
                                <span class="text-[#25D366] text-xs font-bold">WA</span>
                            </div>
                            <div>
                                <h4 class="text-white text-sm font-bold">New Inquiry</h4>
                                <p class="text-white/40 text-xs">WhatsApp +1 (555) 0192</p>
                            </div>
                        </div>
                        <p class="text-white/80 text-sm italic">"Hi, I'm a cash buyer looking at the luxury villa downtown. What's the final price?"</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="scene-journey absolute inset-0 w-full h-full flex items-center justify-center z-30 opacity-0 pointer-events-none px-6 lg:px-20 will-change-transform">
            <div class="w-full max-w-7xl flex flex-col-reverse lg:flex-row items-center gap-12">
                
                <div class="w-full lg:w-1/2 h-[500px] relative perspective-[1200px] flex items-center justify-center">
                    <div class="solution-dash glass-panel w-full max-w-md rounded-3xl p-1 flex flex-col transform rotate-y-6 rotate-x-3 overflow-hidden">
                        <div class="bg-white/5 h-12 border-b border-white/10 flex items-center px-5 justify-between">
                            <div class="text-[10px] font-bold tracking-widest text-emerald-400 uppercase">ZoeyHQ Intelligence Engine</div>
                            <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                        </div>
                        
                        <div class="flex-1 p-5 space-y-4 relative">
                            <div class="msg-card relative bg-white/[0.03] rounded-xl p-5 border border-white/10 opacity-0 translate-y-10 overflow-hidden">
                                
                                <div class="scanner-bar absolute left-0 w-full z-20 opacity-0 scanner-beam pointer-events-none"></div>

                                <div class="flex items-start gap-4 relative z-10">
                                    <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white/50 font-bold text-xs ring-2 ring-white/5">CB</div>
                                    <div class="flex-1">
                                        <div class="flex justify-between items-center mb-2">
                                            <h4 class="font-medium text-white/90 text-sm">Cash Buyer</h4>
                                            <span class="text-[10px] text-white/30">Just now</span>
                                        </div>
                                        <p class="text-white/60 text-sm font-light leading-relaxed">"Hi, I'm a cash buyer looking at the luxury villa downtown. What's the final price?"</p>
                                    </div>
                                </div>

                                <div class="ai-analysis-wrapper h-0 overflow-hidden opacity-0 relative z-10">
                                    <div class="mt-4 pt-4 border-t border-white/5">
                                        <div class="grid grid-cols-2 gap-2 mb-3">
                                            <div class="bg-black/40 rounded p-2 border border-white/5">
                                                <div class="text-[9px] text-white/40 uppercase mb-1">Intent</div>
                                                <div class="text-xs text-emerald-400 font-mono">Purchase / Viewing</div>
                                            </div>
                                            <div class="bg-black/40 rounded p-2 border border-white/5">
                                                <div class="text-[9px] text-white/40 uppercase mb-1">Status</div>
                                                <div class="text-xs text-orange-400 font-mono">Cash Ready</div>
                                            </div>
                                        </div>
                                        <div class="bg-emerald-900/20 rounded-lg p-3 text-xs text-white/70 border border-emerald-500/20 italic">
                                            "Hello! The villa is currently available at $1.5M. I have priority slots open for cash buyers today. Should I book a private tour for you?"
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="w-full lg:w-1/2 relative h-[250px]">
                    <div class="flow-text-1 absolute w-full opacity-100 will-change-transform">
                        <span class="text-emerald-500 tracking-widest text-xs font-bold uppercase mb-4 block">Stage 02 / Ingestion</span>
                        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-4 leading-tight">Instant Capture.</h2>
                        <p class="text-white/60 text-lg font-light leading-relaxed">The message is pulled from the chaos directly into the ZoeyHQ Dashboard.</p>
                    </div>
                    <div class="flow-text-2 absolute w-full opacity-0 translate-y-10 will-change-transform">
                        <span class="text-emerald-500 tracking-widest text-xs font-bold uppercase mb-4 block">Stage 03 / Analysis</span>
                        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-4 leading-tight">Deep Analysis.</h2>
                        <p class="text-white/60 text-lg font-light leading-relaxed">The Neural Engine scans the text and identifies the intent as high-priority.</p>
                    </div>
                    <div class="flow-text-3 absolute w-full opacity-0 translate-y-10 will-change-transform">
                        <span class="text-orange-500 tracking-widest text-xs font-bold uppercase mb-4 block">Stage 04 / Conversion</span>
                        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-4 leading-tight">Converted to <br><span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-500 glow-text-orange">Revenue.</span></h2>
                        <p class="text-white/60 text-lg font-light leading-relaxed">Zoey generates a personalized reply. The message is now a fully qualified Hot Lead.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="scene-ask absolute inset-0 w-full h-full flex flex-col items-center justify-center z-40 opacity-0 pointer-events-none px-6 bg-dark will-change-transform">
            <div class="text-center z-10 max-w-5xl mx-auto w-full">
                <h2 class="text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight mb-6 leading-tight">
                    Fueling the <br>
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500 glow-text-emerald">AI Real Estate Revolution.</span>
                </h2>
                
                <p class="text-white/70 text-xl md:text-2xl font-light mb-12 leading-relaxed max-w-3xl mx-auto">
                    We are raising a minimum of <strong class="text-white font-bold text-3xl">$100,000</strong> in our Seed round for <strong class="text-white font-bold text-3xl">10% equity</strong>.
                </p>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
                    <div class="glass-panel p-6 rounded-3xl text-left border-t-4 border-t-emerald-500 relative overflow-hidden">
                        <div class="text-4xl font-black text-white mb-1 tracking-tighter">30<span class="text-xl text-emerald-500">%</span></div>
                        <div class="text-xs text-emerald-400 font-bold mb-2 uppercase tracking-widest">AI Servers</div>
                        <p class="text-xs text-white/50 font-light leading-relaxed">Scaling LLM API capabilities to handle complex lead interactions.</p>
                    </div>
                    <div class="glass-panel p-6 rounded-3xl text-left border-t-4 border-t-blue-500 relative overflow-hidden">
                        <div class="text-4xl font-black text-white mb-1 tracking-tighter">20<span class="text-xl text-blue-500">%</span></div>
                        <div class="text-xs text-blue-400 font-bold mb-2 uppercase tracking-widest">Dev & Infra</div>
                        <p class="text-xs text-white/50 font-light leading-relaxed">Strengthening core platform stability and omnichannel gateways.</p>
                    </div>
                    <div class="glass-panel p-6 rounded-3xl text-left border-t-4 border-t-orange-500 relative overflow-hidden">
                        <div class="text-4xl font-black text-white mb-1 tracking-tighter">50<span class="text-xl text-orange-500">%</span></div>
                        <div class="text-xs text-orange-400 font-bold mb-2 uppercase tracking-widest">Marketing</div>
                        <p class="text-xs text-white/50 font-light leading-relaxed">Aggressive go-to-market strategy generating a 6-month runway.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from '@studio-freight/lenis';

    gsap.registerPlugin(ScrollTrigger);

    // 1. Initialize Lenis
    const lenis = new Lenis({
        duration: 0.8,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smooth: true,
        smoothTouch: false
    });

    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => { lenis.raf(time * 1000); });
    gsap.ticker.lagSmoothing(0);

    // 2. Optimized Timeline
    const tl = gsap.timeline({
        scrollTrigger: {
            trigger: "#story-pin",
            start: "top top",
            end: "+=5000",
            scrub: 0.5,      
            pin: true,
            anticipatePin: 1
        }
    });

    // PHASE 1: Hero -> Chaos
    tl.addLabel("startChaos")
      .to(".scene-hero", { opacity: 0, y: -50, filter: "blur(10px)", duration: 1 }, "startChaos")
      .to(".orb-hero", { opacity: 0, duration: 1 }, "startChaos")
      .to(".orb-chaos", { opacity: 1, duration: 1 }, "startChaos+=0.5")
      .fromTo(".scene-chaos", 
            { opacity: 0, scale: 1.1, filter: "blur(10px)" }, 
            { opacity: 1, scale: 1, filter: "blur(0px)", duration: 1.5, ease: "power2.out" }, "startChaos+=0.5")
      .from(".target-message", { scale: 0.8, opacity: 0, rotation: -5, duration: 1, ease: "back.out(1.5)"}, "startChaos+=1")
      .to(".target-message", { scale: 1.05, boxShadow: "0 0 80px rgba(225,29,72,0.4)", duration: 1, yoyo: true, repeat: 1 }, "startChaos+=1.5");

    // PHASE 2: Chaos -> Journey (Ingestion)
    tl.addLabel("startJourney", "+=0.5")
      .to(".scene-chaos", { opacity: 0, y: -50, scale: 0.9, filter: "blur(10px)", duration: 1 }, "startJourney")
      .to(".orb-chaos", { opacity: 0, duration: 1 }, "startJourney")
      .to(".orb-solution", { opacity: 1, duration: 1 }, "startJourney+=0.5")
      .fromTo(".scene-journey",
            { opacity: 0, scale: 1.1, y: 50, filter: "blur(15px)" },
            { opacity: 1, scale: 1, y: 0, filter: "blur(0px)", duration: 1.5, ease: "power3.out" }, "startJourney+=0.5")
      .from(".solution-dash", { rotationX: -10, rotationY: -20, z: -200, duration: 1.5, ease: "power2.out" }, "startJourney+=0.5");

    // PHASE 3: Micro-interactions (Scan & Analyze)
    tl.addLabel("ingestMsg", "+=0.5")
      .to(".msg-card", { opacity: 1, y: 0, duration: 1, ease: "back.out(1.2)" }, "ingestMsg");

    tl.addLabel("scanMsg", "+=0.8")
      .to(".flow-text-1", { opacity: 0, y: -30, filter: "blur(5px)", duration: 0.8 }, "scanMsg")
      .to(".flow-text-2", { opacity: 1, y: 0, filter: "blur(0px)", duration: 0.8 }, "scanMsg+=0.2")
      .to(".scanner-bar", { opacity: 1, duration: 0.2 }, "scanMsg")
      .to(".scanner-bar", { y: "500%", duration: 1.5, ease: "power1.inOut" }, "scanMsg+=0.2")
      .to(".scanner-bar", { opacity: 0, duration: 0.2 }, "scanMsg+=1.7")
      .to(".ai-analysis-wrapper", { opacity: 1, height: "auto", duration: 1.2, ease: "power3.out" }, "scanMsg+=1.2");

    // PHASE 4: Conversion to Hot Lead
    tl.addLabel("convertLead", "+=1")
      .to(".flow-text-2", { opacity: 0, y: -30, filter: "blur(5px)", duration: 0.8 }, "convertLead")
      .to(".flow-text-3", { opacity: 1, y: 0, filter: "blur(0px)", duration: 0.8 }, "convertLead+=0.2")
      .to(".orb-solution", { opacity: 0, duration: 1 }, "convertLead")
      .to(".orb-features", { opacity: 1, duration: 1 }, "convertLead")
      .to(".msg-card", { 
          borderColor: "rgba(249, 115, 22, 0.5)", 
          backgroundColor: "rgba(249, 115, 22, 0.05)",
          boxShadow: "0 0 40px rgba(249, 115, 22, 0.15)", 
          scale: 1.02, 
          duration: 1,
          ease: "back.out(1.5)"
      }, "convertLead");

    // PHASE 5: Journey -> Final Ask
    tl.addLabel("startAsk", "+=1")
      .to(".scene-journey", { opacity: 0, y: -50, scale: 0.9, filter: "blur(10px)", duration: 1 }, "startAsk")
      .fromTo(".scene-ask",
            { opacity: 0, scale: 1.1, filter: "blur(15px)" },
            { opacity: 1, scale: 1, filter: "blur(0px)", duration: 1.5, ease: "power3.out" }, "startAsk+=0.5");
</script>
